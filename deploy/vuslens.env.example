# Copy to /opt/vuslens/vuslens.env  (chmod 600, owned by vuslens, NOT in git).
# systemd loads this via EnvironmentFile. Do NOT reuse the main pipeline's
# env file -- this deployment gets its own.

# Reasoning layer (claude-opus-4-8). The deterministic pipeline + auditor run
# WITHOUT a key; without it the Claude panel just shows a "needs credentials"
# note instead of streaming. Set the PRODUCTION key here.
ANTHROPIC_API_KEY=REPLACE_WITH_PRODUCTION_KEY

# --- Subdomain served at ROOT (https://vuslens.aistanbulresearch.com/) ---
# Both stay EMPTY. The browser calls same-origin /api/* on the subdomain, which
# nginx proxies to 127.0.0.1:8001.
#   VUS_ROOT_PATH   -> only for a sub-PATH mount (e.g. /vuslens behind a shared
#                      domain). Empty = app rooted at "/".
#   VUS_PUBLIC_BASE -> prefix the browser prepends to /api/* . Empty = same
#                      origin. Set this ONLY if you ever move to a sub-path.
VUS_ROOT_PATH=
VUS_PUBLIC_BASE=
